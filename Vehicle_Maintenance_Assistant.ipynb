      "cell_type": "code",
      "source": [
        "%%writefile vehicle_maintenance_assistant.py\n",
        "\n",
        "import streamlit as st\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import time\n",
        "\n",
        "# ── PAGE CONFIG ──────────────────────────────────────────────────────────────\n",
        "st.set_page_config(\n",
        "    page_title=\"Vehicle Maintenance Assistant\",\n",
        "    page_icon=\"🚗\",\n",
        "    layout=\"wide\"\n",
        ")\n",
        "\n",
        "# ── TITLE & INTRO ────────────────────────────────────────────────────────────\n",
        "st.title(\"🚗 Vehicle Maintenance Assistant\")\n",
        "st.write(\"\"\"\n",
        "## Selamat datang di Vehicle Maintenance Assistant\n",
        "\n",
        "Aplikasi ini membantu pengguna melakukan:\n",
        "- Diagnosa ringan kendaraan\n",
        "- Monitoring maintenance\n",
        "- Tips perawatan kendaraan\n",
        "- Estimasi servis kendaraan\n",
        "\n",
        "Demo ini menggunakan berbagai komponen dasar Streamlit.\n",
        "\"\"\")\n",
        "\n",
        "# ── 1. TEXT INPUT ────────────────────────────────────────────────────────────\n",
        "st.header(\"1. Informasi Pengguna\")\n",
        "\n",
        "user_name = st.text_input(\n",
        "    \"Masukkan nama Anda\",\n",
        "    \"Ketik nama di sini...\"\n",
        ")\n",
        "\n",
        "vehicle_name = st.text_input(\n",
        "    \"Masukkan tipe kendaraan\",\n",
        "    \"Contoh: Avanza 2020\"\n",
        ")\n",
        "\n",
        "st.write(f\"Halo **{user_name}**, kendaraan Anda adalah **{vehicle_name}**\")\n",
        "\n",
        "# ── 2. BUTTON ────────────────────────────────────────────────────────────────\n",
        "st.header(\"2. Cek Kondisi Kendaraan\")\n",
        "\n",
        "if st.button(\"🔍 Mulai Diagnosa\"):\n",
        "    st.success(\"Diagnosa kendaraan berhasil dilakukan!\")\n",
        "\n",
        "# ── 3. CHECKBOX ──────────────────────────────────────────────────────────────\n",
        "st.header(\"3. Checklist Maintenance\")\n",
        "\n",
        "oil_check = st.checkbox(\"Ganti oli\")\n",
        "brake_check = st.checkbox(\"Periksa rem\")\n",
        "battery_check = st.checkbox(\"Periksa aki\")\n",
        "\n",
        "if oil_check:\n",
        "    st.write(\"✅ Oli kendaraan sudah diperiksa\")\n",
        "\n",
        "if brake_check:\n",
        "    st.write(\"✅ Sistem rem sudah diperiksa\")\n",
        "\n",
        "if battery_check:\n",
        "    st.write(\"✅ Kondisi aki sudah diperiksa\")\n",
        "\n",
        "# ── 4. SELECTBOX ─────────────────────────────────────────────────────────────\n",
        "st.header(\"4. Pilih Jenis Kendaraan\")\n",
        "\n",
        "vehicle_type = st.selectbox(\n",
        "    \"Jenis Kendaraan\",\n",
        "    (\"Mobil\", \"Motor\", \"Truk\")\n",
        ")\n",
        "\n",
        "st.write(f\"Jenis kendaraan yang dipilih: **{vehicle_type}**\")\n",
        "\n",
        "# ── 5. SLIDER ────────────────────────────────────────────────────────────────\n",
        "st.header(\"5. Estimasi Jarak Tempuh\")\n",
        "\n",
        "distance = st.slider(\n",
        "    \"Berapa KM kendaraan Anda?\",\n",
        "    0,\n",
        "    200000,\n",
        "    5000\n",
        ")\n",
        "\n",
        "st.write(f\"Jarak tempuh kendaraan: **{distance} KM**\")\n",
        "\n",
        "# ── 6. PROGRESS BAR ──────────────────────────────────────────────────────────\n",
        "st.header(\"6. Simulasi Maintenance\")\n",
        "\n",
        "progress_bar = st.progress(0)\n",
        "\n",
        "for i in range(100):\n",
        "    time.sleep(0.01)\n",
        "    progress_bar.progress(i + 1)\n",
        "\n",
        "st.success(\"Maintenance selesai dilakukan!\")\n",
        "\n",
        "# ── 7. SIDEBAR ───────────────────────────────────────────────────────────────\n",
        "with st.sidebar:\n",
        "\n",
        "    st.header(\"⚙️ Pengaturan\")\n",
        "\n",
        "    language_style = st.selectbox(\n",
        "        \"Gaya Bahasa\",\n",
        "        (\"Formal\", \"Santai\")\n",
        "    )\n",
        "\n",
        "    service_type = st.selectbox(\n",
        "        \"Jenis Servis\",\n",
        "        (\n",
        "            \"Servis Ringan\",\n",
        "            \"Servis Berkala\",\n",
        "            \"Ganti Oli\",\n",
        "            \"Tune Up\"\n",
        "        )\n",
        "    )\n",
        "\n",
        "    if st.button(\"Reset Sistem\"):\n",
        "        st.warning(\"Sistem berhasil di-reset\")\n",
        "\n",
        "# ── 8. COLUMNS ───────────────────────────────────────────────────────────────\n",
        "st.header(\"8. Status Kendaraan\")\n",
        "\n",
        "col1, col2 = st.columns(2)\n",
        "\n",
        "with col1:\n",
        "    st.metric(\"Tekanan Ban\", \"32 PSI\")\n",
        "    st.metric(\"Kondisi Oli\", \"Baik\")\n",
        "\n",
        "with col2:\n",
        "    st.metric(\"Suhu Mesin\", \"90°C\")\n",
        "    st.metric(\"Kondisi Aki\", \"Normal\")\n",
        "\n",
        "# ── 9. STATUS MESSAGE ────────────────────────────────────────────────────────\n",
        "st.header(\"9. Status Maintenance\")\n",
        "\n",
        "st.success(\"Servis berkala berjalan dengan baik\")\n",
        "st.info(\"Disarankan melakukan pengecekan rem setiap 3 bulan\")\n",
        "st.warning(\"Tekanan ban sedikit rendah\")\n",
        "st.error(\"Oli mesin perlu segera diganti\")\n",
        "\n",
        "# ── 10. CHARTS ───────────────────────────────────────────────────────────────\n",
        "st.header(\"10. Grafik Monitoring Kendaraan\")\n",
        "\n",
        "st.subheader(\"Grafik Konsumsi BBM\")\n",
        "\n",
        "fuel_data = pd.DataFrame(\n",
        "    np.random.randn(20, 3),\n",
        "    columns=[\"Mobil\", \"Motor\", \"Truk\"]\n",
        ")\n",
        "\n",
        "st.line_chart(fuel_data)\n",
        "\n",
        "st.subheader(\"Grafik Biaya Maintenance\")\n",
        "\n",
        "cost_data = pd.DataFrame(\n",
        "    {\n",
        "        \"Servis\": [500000, 750000, 600000, 900000],\n",
        "        \"Sparepart\": [300000, 400000, 350000, 500000]\n",
        "    },\n",
        "    index=[\"Jan\", \"Feb\", \"Mar\", \"Apr\"]\n",
        ")\n",
        "\n",
        "st.bar_chart(cost_data)\n",
        "\n",
        "# ── 11. DATAFRAME ────────────────────────────────────────────────────────────\n",
        "st.header(\"11. Data Kendaraan\")\n",
        "\n",
        "vehicle_data = {\n",
        "    \"Kendaraan\": [\"Avanza\", \"Beat\", \"Pajero\", \"Vario\"],\n",
        "    \"Tahun\": [2020, 2021, 2019, 2022],\n",
        "    \"KM\": [45000, 12000, 67000, 15000],\n",
        "    \"Status\": [\"Baik\", \"Servis\", \"Baik\", \"Perlu Cek\"]\n",
        "}\n",
        "\n",
        "df = pd.DataFrame(vehicle_data)\n",
        "\n",
        "st.write(\"### Data Kendaraan\")\n",
        "st.dataframe(df)\n",
        "\n",
        "st.write(\"### Statistik Kendaraan\")\n",
        "st.write(df.describe())\n",
        "\n",
        "# ── FOOTER ───────────────────────────────────────────────────────────────────\n",
        "st.write(\"---\")\n",
        "st.write(\"🚗 Vehicle Maintenance Assistant | Streamlit Demo Project\")"
      ],
